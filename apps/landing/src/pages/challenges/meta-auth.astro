---
import Background from "../../components/background.astro";
import Content from "../../components/content.astro";
import LinesMenu from "../../components/lines-menu.astro";
import Menu from "../../components/menu.astro";
import Button from "../../components/button.astro";
import RootLayout from "../../layouts/root-layout.astro";
---

<RootLayout
    title="Meta Auth - Coding Challenge"
    description="JWT authentication demo with signup, login, and protected secret access. A FreeCodeCamp backend API challenge using Fastify."
>
    <main class="text-right" x-data="stars">
        <div>
            <Menu />
            <Content>
                <div
                    class="p-8 backdrop-blur-[10px] bg-[rgba(30,53,62,0.3)] text-blue-200"
                    x-data="useMetaAuthForm"
                >
                    <div class="flex items-end w-full justify-end">
                        <LinesMenu />
                    </div>
                    <h1 class="text-pink-400 font-bold font-serif text-[12vw] md:text-[6vw] m-0">
                        Meta Auth
                    </h1>
                    <div class="mb-8">
                        <p>Do your own auth, they said...It would be easy, they said...</p>
                        <p>Try our meta auth with JWT and fastify, source code in Github!</p>
                    </div>
                    <form
                        class="text-blue-200 mb-8 font-mono text-light-green font-bold"
                        method="post"
                        @submit.prevent="noop"
                        id="createMetaUserForm"
                    >
                        <p class="flex items-center mb-4 w-full gap-4">
                            <span> System says: </span>
                            <span
                                class="flex items-center justify-center min-w-32 min-h-14 text-center px-2 py-1 backdrop-blur-[2px] bg-light-green text-blue-900 w-full lg"
                                x-text="systemMessage"></span>
                        </p>
                        <div class="mb-8" x-show="!userCreated || !userLoggedIn" x-cloak>
                            <div class="flex justify-between items-center gap-3 mb-4">
                                <label for="url" class="grow"> Type a username </label>
                                <input
                                    class="grow bg-pink-100 text-blue-900 px-3 py-2"
                                    id="username"
                                    type="text"
                                    minlength="3"
                                    required
                                    name="url"
                                    x-model="username"
                                    placeholder="michael.jackson"
                                />
                            </div>
                            <div class="flex justify-between items-center gap-3">
                                <label for="url" class="grow"> Type a password </label>
                                <input
                                    class="grow bg-pink-100 text-blue-900 px-3 py-2"
                                    id="password"
                                    minlength="8"
                                    type="password"
                                    required
                                    x-model="password"
                                    name="url"
                                    placeholder="thriller123!"
                                />
                            </div>
                        </div>
                        <div class="flex gap-2 flex-col" x-show="!userCreated || !userLoggedIn" x-cloak>
                            <div class="flex gap-2">
                                <div class="grow w-full" x-show="!userCreated && !userLoggedIn">
                                    <Button
                                        class="w-full"
                                        type="submit"
                                        form="createMetaUserForm"
                                        @click="createMetaUser($data)">Signup</Button
                                    >
                                </div>
                                <div class="grow w-full">
                                    <Button
                                        class="w-full"
                                        form="createMetaUserForm"
                                        type="submit"
                                        @click="createMetaSession($data)">Login</Button
                                    >
                                </div>
                            </div>
                            <div x-show="!hiddenSecret " class="grow w-full">
                                <Button variant="ghost" class="w-full" @click="getMetaSession">
                                    Show Secret
                                </Button>
                            </div>
                        </div>
                        <div class="flex gap-2 flex-col" x-show="userLoggedIn" x-cloak>
                            <p class="text-light-green text-md font-mono m-0 text-xl text-center py-10">
                                You are logged in as <strong x-text="username"></strong>
                            </p>
                            <div class="flex gap-2">
                                <div class="grow w-full">
                                    <Button
                                        class="w-full"
                                        type="submit"
                                        form="createMetaUserForm"
                                        @click="deleteMetaSession($data)">Logout</Button
                                    >
                                </div>
                            </div>
                            <div x-show="!hiddenSecret" class="grow w-full">
                                <Button variant="ghost" class="w-full" @click="getMetaSession">
                                    Show Secret
                                </Button>
                            </div>
                            <p
                                x-text="hiddenSecret"
                                x-show="hiddenSecret"
                                class="pt-10 text-2xl text-light-green font-bold text-center"
                            >
                            </p>
                        </div>
                    </form>
                    <Background />
                </div>
                <script src="../../scripts/star-menu-controller"></script>
                <script src="../../scripts/meta-auth"></script>
            </Content>
        </div>
    </main>
</RootLayout>
